NODE_ENV=development

DATABASE_URL="postgresql://atende_pix:atende_pix@localhost:5432/atende_pix?schema=public"
REDIS_URL="redis://localhost:6379"
POSTGRES_CONTAINER="atende-pix-postgres"
POSTGRES_DATABASE="atende_pix"
POSTGRES_USER="atende_pix"
POSTGRES_PASSWORD="atende_pix"
BACKUP_DIR=".backups/postgres"
BACKUP_RETENTION_DAYS=14
ERROR_MONITORING_ENABLED=true
ERROR_MONITORING_CAPTURE_4XX=false
ERROR_LOG_PATH=".logs/api-errors.log"
STRUCTURED_LOGGING_ENABLED=true
STRUCTURED_LOGGING_VERBOSE=false
REQUEST_LOGGING_ENABLED=true

JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_EXPIRES_IN_SECONDS=28800
ADMIN_EMAILS="admin@atendepix.local"

API_PORT=3000
WEB_PORT=5173
VITE_API_BASE_URL="http://localhost:3000"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum MembershipRole {
  OWNER
  MANAGER
  ATTENDANT
  FINANCE
}

enum ProductServiceType {
  PRODUCT
  SERVICE
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum AttendanceOrigin {
  WHATSAPP
  INSTAGRAM
  PHONE
  IN_PERSON
  OTHER
}

enum AttendanceStatus {
  NEW
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_PAYMENT
  DONE
  CANCELED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  document  String?
  phone     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers       Customer[]
  attendances     Attendance[]
  memberships     Membership[]
  productServices ProductService[]
  quotes          Quote[]
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships Membership[]
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  document  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  quotes Quote[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, document])
}

model Attendance {
  id         String           @id @default(cuid())
  tenantId   String
  customerId String
  origin     AttendanceOrigin
  status     AttendanceStatus @default(NEW)
  summary    String?
  internalNotes String?
  responsibleName String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, status])
  @@index([tenantId, origin])
}

model ProductService {
  id          String             @id @default(cuid())
  tenantId    String
  type        ProductServiceType
  name        String
  description String?
  price       Decimal            @db.Decimal(12, 2)
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, active])
}

model Quote {
  id           String      @id @default(cuid())
  tenantId     String
  customerId   String
  attendanceId String?
  number       Int
  status       QuoteStatus @default(DRAFT)
  subtotal     Decimal     @default(0) @db.Decimal(12, 2)
  discount     Decimal     @default(0) @db.Decimal(12, 2)
  total        Decimal     @default(0) @db.Decimal(12, 2)
  validUntil   DateTime?
  publicToken  String      @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    QuoteItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([customerId])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

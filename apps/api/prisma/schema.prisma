generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum MembershipRole {
  OWNER
  MANAGER
  ATTENDANT
  FINANCE
}

enum ProductServiceType {
  PRODUCT
  SERVICE
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum AttendanceOrigin {
  WHATSAPP
  INSTAGRAM
  PHONE
  IN_PERSON
  OTHER
}

enum AttendanceStatus {
  NEW
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_PAYMENT
  DONE
  CANCELED
}

enum OrderStatus {
  OPEN
  WAITING_PAYMENT
  PAID
  IN_PROGRESS
  READY
  DELIVERED
  CANCELED
}

enum PaymentProvider {
  MANUAL
  MERCADO_PAGO
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELED
  FAILED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  document  String?
  phone     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers       Customer[]
  attendances     Attendance[]
  memberships     Membership[]
  productServices ProductService[]
  quotes          Quote[]
  orders          Order[]
  payments        Payment[]
  paymentProviderConfigs PaymentProviderConfig[]
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships Membership[]
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  document  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  quotes      Quote[]
  orders      Order[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, document])
}

model Attendance {
  id         String           @id @default(cuid())
  tenantId   String
  customerId String
  origin     AttendanceOrigin
  status     AttendanceStatus @default(NEW)
  summary    String?
  internalNotes String?
  responsibleName String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quotes   Quote[]

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, status])
  @@index([tenantId, origin])
}

model ProductService {
  id          String             @id @default(cuid())
  tenantId    String
  type        ProductServiceType
  name        String
  description String?
  price       Decimal            @db.Decimal(12, 2)
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, active])
}

model Quote {
  id           String      @id @default(cuid())
  tenantId     String
  customerId   String
  attendanceId String?
  number       Int
  status       QuoteStatus @default(DRAFT)
  subtotal     Decimal     @default(0) @db.Decimal(12, 2)
  discount     Decimal     @default(0) @db.Decimal(12, 2)
  total        Decimal     @default(0) @db.Decimal(12, 2)
  validUntil   DateTime?
  publicToken  String      @unique
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  attendance Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)
  items    QuoteItem[]
  order    Order?

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([customerId])
}

model Order {
  id         String      @id @default(cuid())
  tenantId   String
  customerId String
  quoteId    String?     @unique
  number     Int
  status     OrderStatus @default(OPEN)
  total      Decimal     @default(0) @db.Decimal(12, 2)
  dueDate    DateTime?
  paidAt     DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quote    Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id                String          @id @default(cuid())
  tenantId          String
  orderId           String
  provider          PaymentProvider @default(MANUAL)
  providerPaymentId String?
  status            PaymentStatus   @default(PENDING)
  amount            Decimal         @db.Decimal(12, 2)
  qrCode            String?
  qrCodeText        String?
  paymentUrl        String?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@index([tenantId, status])
}

model PaymentProviderConfig {
  id            String          @id @default(cuid())
  tenantId      String
  provider      PaymentProvider
  active        Boolean         @default(false)
  sandbox       Boolean         @default(true)
  accessToken   String?
  publicKey     String?
  webhookSecret String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([tenantId, active])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}
